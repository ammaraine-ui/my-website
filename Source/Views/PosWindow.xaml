<Window x:Class="AmmarAlani.Views.PosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="نقطة البيع"
        Height="820" Width="1400"
        FlowDirection="RightToLeft"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F7F9FC" Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Height="40" Margin="6" Text="ادخال باركود أو اسم المادة"/>
            <ComboBox Grid.Column="1" Height="40" Margin="6"/>
            <ComboBox Grid.Column="2" Height="40" Margin="6"/>
            <ComboBox Grid.Column="3" Height="40" Margin="6"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.4*"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <DataGrid Margin="0,0,10,0" AutoGenerateColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="المادة" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="الكمية" Binding="{Binding Qty}" Width="100"/>
                    <DataGridTextColumn Header="السعر" Binding="{Binding Price}" Width="120"/>
                    <DataGridTextColumn Header="الخصم" Binding="{Binding Discount}" Width="120"/>
                    <DataGridTextColumn Header="المجموع" Binding="{Binding Total}" Width="140"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Column="1">
                <GroupBox Header="العميل والفاتورة" Margin="0,0,0,10">
                    <StackPanel Margin="10">
                        <ComboBox Height="36" Margin="0,0,0,8"/>
                        <TextBox Height="36" Margin="0,0,0,8" Text="خصم"/>
                        <TextBox Height="36" Margin="0,0,0,8" Text="ملاحظات"/>
                    </StackPanel>
                </GroupBox>
                <GroupBox Header="الإجماليات">
                    <StackPanel Margin="10">
                        <TextBlock Text="الإجمالي: 0.00" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="الخصم: 0.00" Margin="0,0,0,8"/>
                        <TextBlock Text="الصافي: 0.00" FontSize="18" FontWeight="SemiBold"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>

        <UniformGrid Grid.Row="2" Columns="5" Margin="0,12,0,0">
            <Button Content="جديد" Height="48" Margin="6"/>
            <Button Content="حفظ" Height="48" Margin="6"/>
            <Button Content="طباعة" Height="48" Margin="6"/>
            <Button Content="تعليق" Height="48" Margin="6"/>
            <Button Content="خروج" Height="48" Margin="6"/>
        </UniformGrid>
    </Grid>
</Window>
